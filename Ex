// EXERCICE 3 — TODO LIST
///////////////////////////////////////////////////////////////


// tableau contenant les tâches

let todos = []


// fonction pour ajouter une tâche

function ajouterTache(titre) {

  // créer un objet tâche

  let tache = {

    titre: titre,   // nom de la tâche

    fait: false     // par défaut la tâche n’est pas faite

  }

  // ajouter la tâche dans le tableau

  todos.push(tache)

}



// fonction pour marquer une tâche comme faite

function terminerTache(index) {

  // accéder à la tâche dans le tableau

  todos[index].fait = true

}



// fonction pour supprimer une tâche

function supprimerTache(index) {

  // splice supprime un élément du tableau

  todos.splice(index, 1)

}



// tester

ajouterTache("Faire les devoirs")
ajouterTache("Coder en JS")

console.log(todos)

terminerTache(0)

console.log(todos)

supprimerTache(1)

console.log(todos)




