// EXERCICE 4 — COMPTEUR
///////////////////////////////////////////////////////////////


// variable compteur

let compteur = 0



// récupérer les éléments HTML

const boutonPlus = document.getElementById("plus")

const boutonMoins = document.getElementById("moins")

const affichage = document.getElementById("compteur")



// événement clic bouton +

boutonPlus.addEventListener("click", () => {

  // augmenter la valeur

  compteur++

  // afficher la valeur dans la page

  affichage.textContent = compteur

})



// événement clic bouton -

boutonMoins.addEventListener("click", () => {

  // diminuer la valeur

  compteur--

  // afficher la valeur

  affichage.textContent = compteur

})










