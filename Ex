// EXERCICE 2 — FIZZBUZZ
///////////////////////////////////////////////////////////////


// boucle de 1 à 100

for (let i = 1; i <= 100; i++) {

  // vérifier si divisible par 3 ET 5

  if (i % 3 === 0 && i % 5 === 0) {

    console.log("FizzBuzz")

  }

  // divisible par 3

  else if (i % 3 === 0) {

    console.log("Fizz")

  }

  // divisible par 5

  else if (i % 5 === 0) {

    console.log("Buzz")

  }

  // sinon afficher le nombre

  else {

    console.log(i)

  }

}






