// fonction calculatrice
// elle prend 3 paramètres :
// a = premier nombre
// b = deuxième nombre
// op = opérateur (+ - * /)

function calculatrice(a, b, op) {

  // vérifier quel opérateur est utilisé

  if (op === "+") {
    
    // si l’opérateur est "+"
    // on retourne l’addition
    return a + b

  }

  if (op === "-") {

    // soustraction
    return a - b

  }

  if (op === "*") {

    // multiplication
    return a * b

  }

  if (op === "/") {

    // vérifier la division par zéro
    if (b === 0) {

      // division par zéro impossible
      return "Erreur division par zéro"

    }

    // sinon on retourne la division
    return a / b

  }

  // si aucun opérateur valide
  return "Opérateur invalide"

}



// tester la fonction

console.log(calculatrice(10,5,"+"))
console.log(calculatrice(10,5,"-"))
console.log(calculatrice(10,5,"*"))
console.log(calculatrice(10,5,"/"))




