// filter manuel
function filterEven(arr) {

  let result = []

  for (let i = 0; i < arr.length; i++) {

    if (arr[i] % 2 === 0) {
      result.push(arr[i])
    }

  }

  return result
}



// map manuel
function squareAll(arr) {

  let result = []

  for (let i = 0; i < arr.length; i++) {
    result.push(arr[i] * arr[i])
  }

  return result
}



