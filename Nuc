// SECTION 14 — PROBLÈME CLASSIQUE : REVERSE
////////////////////////////////////////////////////////////////

function reverse(arr) {

  let result = []

  for (let i = arr.length - 1; i >= 0; i--) {
    result.push(arr[i])
  }

  return result
}



////////////////////////////////////////////////////////////////
// SECTION 15 — PROBLÈME : CHERCHER MAX
////////////////////////////////////////////////////////////////

function max(arr) {

  let max = arr[0]

  for (let i = 1; i < arr.length; i++) {

    if (arr[i] > max) {
      max = arr[i]
    }

  }

  return max
}



////////////////////////////////////////////////////////////////
// SECTION 16 — PROBLÈME : SOMME
////////////////////////////////////////////////////////////////

function sum(arr) {

  let total = 0

  for (let i = 0; i < arr.length; i++) {
    total += arr[i]
  }

  return total
}



