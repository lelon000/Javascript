///////////////////////////////////////////////////////////////
// 14 — EVENT LISTENER
///////////////////////////////////////////////////////////////


// récupérer un bouton

const bouton = document.getElementById("btn")


// écouter un événement click

bouton.addEventListener("click", () => {

  // ce code s’exécute quand l’utilisateur clique

  console.log("Bouton cliqué")

})



///////////////////////////////////////////////////////////////
// 15 — COMPTEUR DE CLIC
///////////////////////////////////////////////////////////////


let clics = 0


document.getElementById("btn").addEventListener("click", () => {

  // augmenter la variable clics
  clics++

  // afficher la valeur dans la page HTML
  document.getElementById("compteur").textContent = "Clics : " + clics

})



///////////////////////////////////////////////////////////////
// 16 — TIMER (TRÈS IMPORTANT POUR TON CONTROLE)
///////////////////////////////////////////////////////////////


// variable qui stocke le temps
let time = 0


// setInterval exécute du code en boucle
// toutes les X millisecondes

const intervalId = setInterval(() => {

  // augmenter le temps
  time++

  // afficher dans la console
  console.log(time)

}, 1000)


// 1000 millisecondes = 1 seconde



///////////////////////////////////////////////////////////////
// 17 — ARRETER LE TIMER
///////////////////////////////////////////////////////////////


// clearInterval permet d’arrêter un setInterval

clearInterval(intervalId)



///////////////////////////////////////////////////////////////
// 18 — TIMER AVEC AFFICHAGE HTML
///////////////////////////////////////////////////////////////


let seconds = 0


let timer = setInterval(() => {

  seconds++

  // afficher le temps dans la page HTML
  document.getElementById("timer").textContent = seconds

}, 1000)



///////////////////////////////////////////////////////////////
// 19 — COUNTDOWN
///////////////////////////////////////////////////////////////


let countdown = 10


let timer2 = setInterval(() => {

  document.getElementById("timer").textContent = countdown

  countdown--

  if (countdown < 0) {

    clearInterval(timer2)

    document.getElementById("timer").textContent = "Terminé"

  }

}, 1000)



///////////////////////////////////////////////////////////////
// 20 — setTimeout
///////////////////////////////////////////////////////////////


// setTimeout exécute une fonction UNE SEULE FOIS après un délai

setTimeout(() => {

  console.log("2 secondes passées")

}, 2000)



